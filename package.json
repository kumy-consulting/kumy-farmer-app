{
  "name": "kumy-farmer-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Kumy — application mobile des agriculteurs (Capacitor + React). Suite AgriPilot.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "check:hosting": "node scripts/check-hosting-config.mjs",
    "deploy:dev": "npm run build && npx firebase-tools deploy --only hosting --config firebase.dev.json --project development",
    "deploy:prod": "npm run build && npx firebase-tools deploy --only hosting --config firebase.prod.json --project production",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky",
    "cap:sync": "npm run build && cap sync",
    "cap:add:android": "cap add android",
    "cap:add:ios": "cap add ios"
  },
  "dependencies": {
    "@capacitor/app": "^7.1.2",
    "@capacitor/camera": "^7.0.5",
    "@capacitor/core": "^7.6.7",
    "@capacitor/filesystem": "^7.1.8",
    "@capacitor/geolocation": "^7.1.8",
    "@capacitor/network": "^7.0.4",
    "@capacitor/preferences": "^7.0.4",
    "@capacitor/push-notifications": "^7.0.6",
    "@capacitor/splash-screen": "^7.0.5",
    "@capacitor/status-bar": "^7.0.6",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.4",
    "@mui/material": "^7.3.4",
    "@mui/x-date-pickers": "^9.0.2",
    "@turf/turf": "^7.2.0",
    "axios": "^1.13.5",
    "dayjs": "^1.11.20",
    "dexie": "^4.2.1",
    "dexie-react-hooks": "^4.2.0",
    "firebase": "^12.5.0",
    "leaflet": "^1.9.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.9.4",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.6.7",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^9.36.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^3.2.7",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "eslint-plugin-unused-imports": "^4.1.4",
    "fake-indexeddb": "^6.2.5",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "vite": "^7.1.7",
    "vite-plugin-pwa": "^1.1.0",
    "vitest": "^3.2.7"
  }
}
